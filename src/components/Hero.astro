---
---
<section class="relative min-h-[80vh] flex items-center justify-center pt-16">
  <!-- Grid background effect -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(142,196,155,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(142,196,155,0.03)_1px,transparent_1px)] bg-[size:4rem_4rem]"></div>
  <!-- Glow -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-sjvik-green/5 rounded-full blur-[120px]"></div>
  
  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <!-- Logo -->
    <div class="mb-8">
      <img src="/logo.png" alt="SJVIK Labs" class="w-28 h-28 mx-auto rounded-2xl shadow-lg shadow-sjvik-green/10" />
    </div>

    <!-- Terminal-style intro -->
    <div class="inline-block mb-8 px-4 py-2 rounded-lg bg-sjvik-surface border border-sjvik-border font-mono text-sm text-sjvik-text-muted">
      <span class="text-sjvik-green">$</span> whoami
      <span class="ml-2 text-sjvik-text">steven.vik</span>
      <span class="mx-2 text-sjvik-border">|</span>
      <span class="text-sjvik-green">cybersecurity</span>
      <span class="mx-1 text-sjvik-border">·</span>
      <span class="text-sjvik-green">devops</span>
      <span class="mx-1 text-sjvik-border">·</span>
      <span class="text-sjvik-green">creator</span>
    </div>

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-6">
      <span class="text-sjvik-green font-mono">SJVIK Labs</span>
    </h1>
    <p class="text-xl sm:text-2xl text-sjvik-text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      Security tools, homelab guides, and digital products.<br class="hidden sm:block" />
      Built by a practitioner, for practitioners.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#products" class="px-6 py-3 bg-sjvik-green text-sjvik-bg font-mono font-semibold rounded-lg hover:bg-sjvik-green-light transition-colors">
        Browse Products
      </a>
      <a href="https://github.com/stevenjvik" target="_blank" rel="noopener" class="px-6 py-3 border border-sjvik-border text-sjvik-text font-mono rounded-lg hover:border-sjvik-green hover:text-sjvik-green transition-colors">
        View on GitHub
      </a>
    </div>
  </div>
</section>
