---
const repos = [
  {
    name: "soc-lab",
    description: "SOC / security engineering reference library — IR playbooks, Sigma detection rules, hardening baselines, automation scripts, and monitoring configs.",
    language: "Python",
    languageColor: "#3572A5",
    url: "https://github.com/sjviklabs/soc-lab"
  },
  {
    name: "tahala",
    description: "Campaign portal for the TCEA D&D campaign. Session timelines, character dossiers, audio/video content, and an AI-powered archivist.",
    language: "TypeScript",
    languageColor: "#3178C6",
    url: "https://tahala.stevenjvik.tech"
  }
];
---

<section id="open-source" class="py-24 px-6 bg-sjvik-surface/30">
  <div class="max-w-6xl mx-auto">
    <div class="mb-12">
      <p class="font-mono text-sjvik-green text-sm mb-2">// open-source</p>
      <h2 class="text-3xl font-bold">Open Source</h2>
      <p class="text-sjvik-text-muted mt-2 max-w-xl">Public projects and tools. Built in the open, free to use.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {repos.map((repo) => (
        <a 
          href={repo.url}
          target="_blank"
          rel="noopener"
          class="group block rounded-xl border border-sjvik-border bg-sjvik-surface p-6 hover:border-sjvik-green transition-all duration-200 hover:-translate-y-1"
        >
          <div class="flex items-center gap-3 mb-3">
            <svg class="w-5 h-5 text-sjvik-text-muted" fill="currentColor" viewBox="0 0 16 16">
              <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z"/>
            </svg>
            <span class="font-mono font-semibold group-hover:text-sjvik-green transition-colors">{repo.name}</span>
          </div>
          <p class="text-sjvik-text-muted text-sm leading-relaxed mb-4">{repo.description}</p>
          <div class="flex items-center gap-2 text-xs font-mono text-sjvik-text-muted">
            <span class="w-3 h-3 rounded-full" style={`background-color: ${repo.languageColor}`}></span>
            <span>{repo.language}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
